    tnom=27 scalem=1.0 scale=1.0 gmin=1e-9 cmin=1e-15 rforce=1 maxnotes=5 maxwarns=5 \
    digits=5 cols=80 pivrel=1e-3 sensfile="../psf/sens.output" \
    checklimitdest=psf 
tran tran stop=500u write="spectre.ic" writefinal="spectre.fc" \
