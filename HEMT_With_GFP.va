parameter real		AVTO 		   = 0.0 		    from (-inf:inf)		     `ATTR(info="MATCHING PARAMETER FOR THQOFFHOLD VOLTAGE (VTO)");
																						     
parameter real		AGAMMA 		= 0.0 		from (-inf:inf)		     `ATTR(info="MATCHING PARAMETER FOR BODY FACTOR (GAMMA)");
																						     
parameter real		AKP		        = 0.0 		from (-inf:inf)		     `ATTR(info="MATCHING PARAMETER FOR MOBILITY (KP)");
																						     
parameter real		ADPHIEDGE	 = 0.0 		from (-inf:inf)		     `ATTR(info="MATCHING PARAMETER FOR THRESHOLD VOLTAGE OF EDGE DEVICE(DPHIEDGE)");
																						     
parameter real		EDGEP1	    	= 0.0 		from (-inf:inf)		     `ATTR(info="EDGEP1");
																						     
parameter real		EDGEP2		= 0.0 		from (-inf:inf)		     `ATTR(info="EDGEP2");
																						     
parameter real		STDC		        = 0.0 		from (-inf:inf)		     `ATTR(info="STDC");

parameter real       AGAMMAEDGE = 0.0        from (-inf:inf)	       	`ATTR(info="AGAMMAEDGE");

