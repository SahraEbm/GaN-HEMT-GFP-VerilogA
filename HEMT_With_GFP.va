parameter real		XJ 		= 20.0E-09 	  from (0.0:inf)		`ATTR(info="DEPTH OF JUNCTION (SOURCE AND DRAIN)");
 
parameter real      NA      = (1e16)*(1e6)      from (0.0:inf)		`ATTR(info="Doping of GaN layer");
 
