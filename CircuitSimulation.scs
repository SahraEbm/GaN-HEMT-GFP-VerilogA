C02 (net012 0) capacitor c=1n
V05 (net011 0) vsource dc=4.3 type=dc
V06 (net051 0) vsource dc=1 type=dc
V14 (net026 0) vsource dc=1 type=dc
V17 (net019 net012) vsource dc=4.3 type=dc
V13 (0 net013) vsource dc=0 type=dc
V8 (net019 net028) vsource dc=0 type=dc
V2 (net019 0) vsource dc=150 type=dc
I62 (net036 LS_ON_LS net030) sw_no vth=0.5 ron=1 roff=1e+07 tconv=0 \
        trise=4e-09 tfall=4e-09 slack=1e-09 vtol=0.01
I61 (net046 net032 net016) sw_no vth=0.5 ron=1 roff=1e+07 tconv=0 \
        trise=4e-09 tfall=4e-09 slack=1e-09 vtol=0.01
I59 (G_HS net037 net018) sw_no vth=0.5 ron=1 roff=1e+07 tconv=0 \
        trise=4e-09 tfall=4e-09 slack=1e-09 vtol=0.01
I60 (G_HS LS_ON_HS net029) sw_no vth=0.5 ron=3 roff=1e+07 tconv=0 \
        trise=4e-09 tfall=4e-09 slack=1e-09 vtol=0.01
V0 (LS_ON_HS 0) vsource type=pulse val0=0 val1=1 period=10u delay=1n \
        rise=18n fall=5n width=4.95u
V1 (LS_ON_LS 0) vsource type=pulse val0=0 val1=1 period=10u delay=5u \
        rise=26n fall=5n width=4.95u
I57 (net027 net076 0 0) HEMT_With_GFP 
I58 (net019 G_HS net017 net017) HEMT_With_GFP 
