//parameter real 	TH_NOI  	 = 0.0	   	 from [0:1]		            `ATTR(info="FLAG TURNING ON SHORT CHANNEL EFFECTS THERMAL NOISE MODEL. (NOT BOTH NQS_NOI AND TH_NOI SHOULD BE SET TO 1).");

parameter real 		INFO_LEVEL = 0.0		   from [0:inf)		        `ATTR(info="FLAG FOR INFORMATION PRINTOUT. CURRENTLY ONLY VALUE OF 1 IS SUPPORTED."); 

parameter real		QOFF 		   = 0.0		    from [0:1]		         `ATTR(info="FLAG FOR TURNING OFF THE DYNAMIC BEHAVIOUR OF THE MODEL (FOR DEBUGGING PURPOSES)");

